# Nginx vhost para freejolitos.com
# Colocar en: /etc/nginx/sites-available/freejolitos.com
# Activar: ln -s /etc/nginx/sites-available/freejolitos.com /etc/nginx/sites-enabled/

server {
    listen 80;
    server_name freejolitos.com www.freejolitos.com;
    return 301 https://freejolitos.com$request_uri;
}

server {
    listen 443 ssl http2;
    server_name www.freejolitos.com;

    ssl_certificate     /etc/letsencrypt/live/freejolitos.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/freejolitos.com/privkey.pem;

    return 301 https://freejolitos.com$request_uri;
}

server {
    listen 443 ssl http2;
    server_name freejolitos.com;

    ssl_certificate     /etc/letsencrypt/live/freejolitos.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/freejolitos.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    add_header Strict-Transport-Security "max-age=63072000" always;

    root /var/www/freejolitos.com;
    index index.html;

    # Rutas de Astro (trailing slash en astro.config: trailingSlash: 'always')
    location / {
        try_files $uri $uri/ $uri/index.html =404;
    }

    # Assets con hash — cache agresivo
    location ~* \.(js|css|woff2|woff|svg|png|ico|webp)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # HTML — no cachear
    location ~* \.html$ {
        expires -1;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    # RSS
    location = /rss.xml {
        expires 1h;
        add_header Cache-Control "public";
        default_type application/rss+xml;
    }

    # 404 personalizado
    error_page 404 /404.html;
    location = /404.html {
        internal;
    }

    # Seguridad
    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";
    add_header Referrer-Policy "no-referrer-when-downgrade";
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()";
}
