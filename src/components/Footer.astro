---
---
<footer>
  <div class="footer-inner">
    <span class="footer-sig">:wq!</span>
    <div class="footer-links">
      <a href="https://matrix.freejolitos.com" rel="noopener">Matrix</a>
      <a href="https://twitter.com/freejolitos" rel="noopener">Twitter</a>
      <a href="/rss.xml">RSS</a>
    </div>
    <img
      src="/logos/bean.svg"
      alt="Freejolitos bean"
      width="24"
      height="24"
      class="footer-bean"
      loading="lazy"
    />
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--stroke);
    padding: 1rem var(--pad);
    margin-top: 3rem;
    font-size: 0.82rem;
    color: var(--fg-dim);
  }

  .footer-inner {
    max-width: calc(var(--max-w) + var(--pad) * 2);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-sig {
    font-weight: 700;
    color: var(--fg-dim);
    letter-spacing: -0.02em;
  }

  .footer-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--fg-dim);
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--fg);
    text-shadow: var(--glow-sm);
  }

  .footer-bean {
    margin-left: auto;
    opacity: 0.5;
    filter: invert(1) sepia(1) saturate(2) hue-rotate(50deg);
    transition: opacity 0.2s;
  }

  .footer-bean:hover {
    opacity: 0.9;
  }
</style>
