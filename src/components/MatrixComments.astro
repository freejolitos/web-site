---
interface Props {
  slug?: string;
}
const { slug } = Astro.props;
const room = slug
  ? `#blog-${slug}:freejolitos.com`
  : '#general:freejolitos.com';
---
<div class="matrix-comments">
  <hr class="divider" />
  <p class="comments-label">
    Comentarios y discusión en Matrix:
    <a
      href={`https://matrix.to/#/${encodeURIComponent(room)}`}
      rel="noopener noreferrer"
      class="matrix-room"
    >{room}</a>
  </p>
</div>

<style>
  .matrix-comments {
    margin-top: 3rem;
    font-size: 0.88rem;
    color: var(--fg-dim);
  }

  .comments-label {
    margin: 0;
  }

  .matrix-room {
    color: var(--fg);
    font-family: var(--font);
  }
</style>
