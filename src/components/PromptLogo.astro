---
interface Props {
  size?: number;
  glow?: boolean;
  class?: string;
}
const { size = 40, glow = false, class: className = '' } = Astro.props;
---
<svg
  class={`prompt-logo${glow ? ' prompt-logo--glow' : ''}${className ? ' ' + className : ''}`}
  viewBox="0 0 100 100"
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  role="img"
  aria-label="Freejolitos"
>
  <rect width="100" height="100" fill="var(--fg)"/>
  <rect x="6" y="6" width="88" height="88" fill="var(--bg)"/>
  <text
    x="9" y="67"
    font-family="'Courier New', Courier, monospace"
    font-size="56"
    font-weight="bold"
    fill="var(--fg)"
  >#</text>
  <rect x="53" y="72" width="30" height="9" fill="var(--fg)"/>
</svg>
