---
interface Props {
  size?: number;
  class?: string;
}
const { size = 120, class: className = '' } = Astro.props;
---
<img
  src="/logos/bean.svg"
  alt="Freejolitos bean"
  width={size}
  height={size}
  class={`bean-egg${className ? ' ' + className : ''}`}
  loading="lazy"
/>

<style>
  .bean-egg {
    opacity: 0.35;
    filter: invert(1) sepia(1) saturate(2) hue-rotate(50deg);
    transition: opacity 0.3s;
  }

  .bean-egg:hover {
    opacity: 0.8;
  }
</style>
